# ── Server Configuration
PORT=5001

# ── Database Configuration
# Leave blank to use the secure container-local MongoDB service automatically.
# Otherwise, specify a MongoDB Atlas connection string to connect to a cloud database.
MONGODB_URI=

# ── AI Model Configuration
# Set LLM_PROVIDER to "google", "openai", or "anthropic"
LLM_PROVIDER=anthropic
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: custom model version overrides
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── Stripe Payment Configuration
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Get from: https://dashboard.stripe.com/webhooks (after creating webhook endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products in Stripe Dashboard and paste their Price IDs here
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_POPULAR=price_...
STRIPE_PRICE_PRO=price_...
# Your public app URL (used for Stripe redirect after payment)
APP_URL=https://repograph.ovijit.com
