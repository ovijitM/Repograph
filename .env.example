# ── Server Configuration
PORT=5001

# ── Database Configuration
# Leave blank to use the secure container-local MongoDB service automatically.
# Otherwise, specify a MongoDB Atlas connection string to connect to a cloud database.
MONGODB_URI=

# ── AI Model Configuration
# Set LLM_PROVIDER to "google", "openai", or "anthropic"
LLM_PROVIDER=google
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: custom model version overrides
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
