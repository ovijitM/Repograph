PORT=5000
MONGODB_URI=mongodb://localhost:27017/repograph

# AI Provider Configurations
# Set LLM_PROVIDER to "google", "openai" or "anthropic". Default is "anthropic".
LLM_PROVIDER=anthropic

# API Keys (at least one is required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Specific AI Models (Optional, fallbacks to defaults if unset)
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
